# Copy this file to .env and fill in the real spreadsheet / folder IDs.
# .env is git-ignored and must never be committed.

# Main student database (CMC Database)
SPREADSHEET_ID_CMC_DATABASE=

# Dismissed students archive
SPREADSHEET_ID_DISMISSED_STUDENTS=

# Response-form table (auto-created by Google Form)
SPREADSHEET_ID_RESPONSE_FORM=

# Public student status / admission status table
SPREADSHEET_ID_STUDENT_STATUS=

# OPK student database
SPREADSHEET_ID_OPK_DATABASE=

# Google Drive folder where generated documents are saved
DOCS_FOLDER_ID=
